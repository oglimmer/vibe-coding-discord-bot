DISCORD_TOKEN=your_discord_bot_token_here
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=vibe-bot
DB_PASSWORD=foobar
DB_NAME=vibe-bot

# 1337 Game Configuration
GAME_START_TIME=13:37:00.000
SERGEANT_ROLE_ID=your_sergeant_role_id
COMMANDER_ROLE_ID=your_commander_role_id
GENERAL_ROLE_ID=your_general_role_id
ANNOUNCEMENT_CHANNEL_ID=your_announcement_channel_id

# Klugscheißer Configuration
OPENAI_API_KEY=your_openai_api_key_here
KLUGSCHEISSER_ENABLED=true
KLUGSCHEISSER_PROBABILITY=10
KLUGSCHEISSER_MIN_LENGTH=100
KLUGSCHEISSER_MAX_TOKENS=200
KLUGSCHEISSER_MODEL=gpt-3.5-turbo
KLUGSCHEISSER_COOLDOWN_SECONDS=60
KLUGSCHEISSER_REQUIRE_OPTIN=true

# Reaction-based Fact Checking
FACTCHECK_REACTION_EMOJI=🔍
FACTCHECK_DAILY_LIMIT_PER_USER=5

# Vibecode (self-extending bot via /vibecode)
VIBECODE_ENABLED=false
DEEPSEEK_API_KEY=your_deepseek_api_key_here
# Fine-grained PAT with contents:write + pull_requests:write on the repo
VIBECODE_GITHUB_TOKEN=your_github_token_here
VIBECODE_REPO=oglimmer/vibe-coding-discord-bot
VIBECODE_BASE_BRANCH=main
VIBECODE_WORKER_IMAGE=ghcr.io/oglimmer/vibe-coding-discord-bot-worker:latest
VIBECODE_MODEL=deepseek/deepseek-v4-pro
# Namespace for worker jobs (default: the bot's own namespace in-cluster)
#VIBECODE_NAMESPACE=
# K8s secret holding DEEPSEEK_API_KEY and VIBECODE_GITHUB_TOKEN for the worker
VIBECODE_SECRET_NAME=discord-bot-secrets
#VIBECODE_IMAGE_PULL_SECRET=oglimmerregistrykey
VIBECODE_JOB_TIMEOUT_SECONDS=2700
VIBECODE_COOLDOWN_SECONDS=900
VIBECODE_MAX_CONCURRENT_JOBS=1

# Postillon RSS feed
POSTILLON_ENABLED=false
POSTILLON_CHANNEL_ID=123456789012345678
POSTILLON_FEED_URL=https://www.der-postillon.com/feeds/posts/default?alt=rss&max-results=50&start-index=1
POSTILLON_POLL_INTERVAL_MINUTES=15
POSTILLON_TIMEZONE=Europe/Berlin
POSTILLON_ANNOUNCE_FIRST_SYNC=false
POSTILLON_REQUEST_TIMEOUT_SECONDS=20
POSTILLON_DELIVERY_DELAY_SECONDS=1
POSTILLON_LEASE_SECONDS=1800
